<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Decluttr" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Dark color palette -->
        <item name="colorPrimary">@color/Primary80</item>
        <item name="colorSecondary">@color/Secondary80</item>
        <item name="colorTertiary">@color/Tertiary80</item>
        <item name="android:colorBackground">@color/DarkBackground</item>
        <item name="colorSurface">@color/DarkSurface</item>
        <item name="colorOnPrimary">@color/DarkBackground</item>
        <item name="colorOnPrimaryContainer">@color/DarkBackground</item>
        <item name="colorOnSecondaryContainer">@color/DarkBackground</item>
        <item name="colorOnTertiaryContainer">@color/DarkBackground</item>
        <item name="colorOnSecondary">@color/DarkPrimaryText</item>
        <item name="colorOnTertiary">@color/DarkPrimaryText</item>
        <item name="colorOnBackground">@color/DarkPrimaryText</item>
        <item name="colorOnSurface">@color/DarkPrimaryText</item>
        <item name="colorOnSurfaceVariant">@color/DarkSecondaryText</item>
        <item name="colorError">#ff6e84</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and icon background -->
        <item name="windowSplashScreenBackground">@color/DarkBackground</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_foreground</item>
        <!-- Set the theme of the Activity that directly follows your splash screen. -->
        <item name="postSplashScreenTheme">@style/Theme.Decluttr</item>
    </style>

    <style name="SquircleIconShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">22%</item>
    </style>
</resources>
