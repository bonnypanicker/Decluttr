<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/discovery_item_horizontal_margin"
    android:layout_marginBottom="16dp"
    android:layout_marginTop="8dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_storage_meter_card_purple"
        android:padding="24dp">

        <ImageView
            android:id="@+id/storage_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_cleaning_services"
            android:rotation="-45"
            app:tint="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/storage_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/discovery_storage_estimated_label"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/storage_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/storage_icon"
            app:layout_constraintBottom_toTopOf="@id/storage_subtitle"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/storage_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text="@string/discovery_storage_subtitle_empty"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="#CCFFFFFF"
            app:layout_constraintStart_toEndOf="@id/storage_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/storage_label" />

        <TextView
            android:id="@+id/storage_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="0 MB"
            android:textAppearance="?attr/textAppearanceDisplayMedium"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/storage_subtitle" />

        <TextView
            android:id="@+id/waste_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_storage_meter_stat_chip_purple"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="@string/discovery_storage_score_default"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/storage_value"
            app:layout_constraintTop_toTopOf="@id/storage_value" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/storage_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:indicatorColor="@android:color/white"
            app:trackColor="#4A3F74"
            app:trackCornerRadius="6dp"
            app:trackThickness="12dp"
            android:max="100"
            android:progress="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/storage_value" />

        <TextView
            android:id="@+id/storage_motivation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/discovery_storage_motivation_empty"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/storage_progress" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
