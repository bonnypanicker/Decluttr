<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_rating_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enjoying Decluttr?"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface" />

    <TextView
        android:id="@+id/tv_rating_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Pick a star rating and share your feedback on Play Store."
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <LinearLayout
        android:id="@+id/stars_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/star_1"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Rate 1 star"
            android:padding="4dp"
            android:src="@drawable/ic_star_outline"
            app:tint="?attr/colorOnSurfaceVariant" />

        <ImageButton
            android:id="@+id/star_2"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Rate 2 stars"
            android:padding="4dp"
            android:src="@drawable/ic_star_outline"
            app:tint="?attr/colorOnSurfaceVariant" />

        <ImageButton
            android:id="@+id/star_3"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Rate 3 stars"
            android:padding="4dp"
            android:src="@drawable/ic_star_outline"
            app:tint="?attr/colorOnSurfaceVariant" />

        <ImageButton
            android:id="@+id/star_4"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Rate 4 stars"
            android:padding="4dp"
            android:src="@drawable/ic_star_outline"
            app:tint="?attr/colorOnSurfaceVariant" />

        <ImageButton
            android:id="@+id/star_5"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Rate 5 stars"
            android:padding="4dp"
            android:src="@drawable/ic_star_outline"
            app:tint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_selected_rating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text=""
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorPrimary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_rating_maybe_later"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maybe later" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_rating_rate_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:enabled="false"
            android:text="Rate on Play Store" />
    </LinearLayout>

</LinearLayout>
