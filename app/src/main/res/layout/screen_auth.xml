<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0c10">

    <!-- Ambient background gradients matching new design -->
    <!-- Top Left Primary Blur -->
    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="top|start"
        android:background="#331e2b58"
        android:translationX="-50dp"
        android:translationY="-50dp" />

    <!-- Right Indigo Blur -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_vertical|end"
        android:background="#660f111a"
        android:translationX="50dp" />

    <!-- Bottom Left Gold Blur -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="bottom|start"
        android:background="#0Cd4af37"
        android:translationX="-50dp"
        android:translationY="50dp" />

    <!-- TopAppBar equivalent (Skip Button on Top Right) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">
        <ImageView
            android:id="@+id/btn_skip"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#94a3b8"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/auth_skip" />
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="48dp">

            <!-- App Branding Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginBottom="48dp">

                <!-- Icon Box -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_editorial_gradient"
                    android:layout_marginBottom="24dp">
                    <!-- Layer icon using a vector drawable or placeholder -->
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="#d4af37" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Decluttr"
                    android:textColor="#e2e8f0"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_app_tagline"
                    android:textColor="#94a3b8"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:maxWidth="280dp" />
            </LinearLayout>

            <!-- Form Card (liquid-glass) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_container_low"
                android:padding="32dp"
                android:maxWidth="440dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL ADDRESS"
                    android:textColor="#94a3b8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_surface_container_low"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp"
                    android:textColor="#e2e8f0"
                    android:textColorHint="#6694a3b8"
                    android:hint="name@example.com"
                    android:inputType="textEmailAddress"
                    android:maxLines="1" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="4dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="PASSWORD"
                        android:textColor="#94a3b8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FORGOT PASSWORD?"
                        android:textColor="#d4af37"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_surface_container_low"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp"
                    android:textColor="#e2e8f0"
                    android:textColorHint="#6694a3b8"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tv_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#ff6e84"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/btn_primary_action"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_editorial_gradient"
                        android:paddingVertical="16dp"
                        android:text="Sign In"
                        android:textColor="#ffffff"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true" />

                    <ProgressBar
                        android:id="@+id/progress_loading"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="#ffffff"
                        android:visibility="gone" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/divider_or"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="16dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#1Affffff" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:text="OR CONTINUE WITH"
                        android:textColor="#9994a3b8"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#1Affffff" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_google_signin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_google_button"
                    android:paddingVertical="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_google_logo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Sign in with Google"
                        android:textColor="#e2e8f0"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Footer Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account?"
                    android:textColor="#94a3b8"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_mode_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Create Account"
                    android:textColor="#d4af37"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>