<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Ambient background gradients matching new design -->
    <!-- Top Left Primary Blur -->
    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="top|start"
        android:background="?attr/colorPrimaryContainer"
        android:alpha="0.2"
        android:translationX="-50dp"
        android:translationY="-50dp" />

    <!-- Right Indigo Blur -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_vertical|end"
        android:background="?attr/colorSecondaryContainer"
        android:alpha="0.4"
        android:translationX="50dp" />

    <!-- Bottom Left Gold Blur -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="bottom|start"
        android:background="?attr/colorTertiaryContainer"
        android:alpha="0.05"
        android:translationX="-50dp"
        android:translationY="50dp" />

    <ScrollView
        android:id="@+id/auth_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="48dp">

            <!-- App Branding Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginBottom="48dp">

                <!-- Icon Box -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_editorial_gradient"
                    android:layout_marginBottom="24dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@mipmap/ic_launcher_round" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Decluttr"
                    android:textColor="?attr/colorOnSurface"
                    android:textAppearance="?attr/textAppearanceDisplaySmall"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_app_tagline"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:gravity="center"
                    android:maxWidth="280dp" />
            </LinearLayout>

            <!-- Auth Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_container_low"
                android:padding="32dp"
                android:maxWidth="440dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_google_only_subtitle"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:id="@+id/tv_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textColor="?attr/colorError"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:visibility="gone" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_google_signin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingVertical="16dp"
                        android:text="@string/auth_google_signin"
                        app:icon="@drawable/ic_google_logo"
                        app:iconTint="@null"
                        app:iconPadding="12dp"
                        app:iconGravity="textStart" />

                    <ProgressBar
                        android:id="@+id/progress_loading"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
